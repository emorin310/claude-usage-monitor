# Claude Usage Monitor — Configuration
# Copy this file to .env and fill in values

# Your claude.ai session key (starts with sk-ant-sid02-)
# How to get it: open claude.ai in Chrome → DevTools → Application → Cookies → sessionKey
# The fetch-claude-usage.swift in ~/.claude already has this injected by the Claude Usage app.
CLAUDE_SESSION_KEY=

# Your organization ID (UUID from claude.ai)
# Found in the fetch-claude-usage.swift file at ~/.claude/fetch-claude-usage.swift
CLAUDE_ORG_ID=

# Optional settings
PORT=3847
USAGE_POLL_MS=30000
