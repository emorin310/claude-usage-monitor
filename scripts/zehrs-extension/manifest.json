{
  "manifest_version": 3,
  "name": "Zehrs Grocery Assistant",
  "version": "1.0",
  "description": "Captures Zehrs authentication and cart data for grocery automation",
  
  "permissions": [
    "storage",
    "activeTab",
    "webRequest"
  ],
  
  "host_permissions": [
    "https://www.zehrs.ca/*",
    "https://api.pcexpress.ca/*"
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "content_scripts": [
    {
      "matches": ["https://www.zehrs.ca/*"],
      "js": ["content.js"]
    }
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "Zehrs Assistant"
  },
  
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://www.zehrs.ca/*"]
    }
  ]
}